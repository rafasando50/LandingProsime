---
const categories = [
	{
		title: "Válvulas Manuales",
		products: [
			"Válvulas de bola",
			"Válvulas de compuerta",
			"Válvulas de globo",
			"Válvulas de mariposa",
			"Válvulas de retencion",
			"Válvulas de aplicaciones especiales"
		],
		image: "/valvulas.png",
		icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M3 12h6"></path><path d="M15 12h6"></path><path d="M12 3v6"></path><path d="M12 15v6"></path><circle cx="12" cy="12" r="8"></circle></svg>` // Valve Wheel icon
	},
	{
		title: "Válvulas de Control",
		products: [
			"Globo de Control",
			"Bola segmentada",
			"Mariposa de Alto Rendimiento",
			"Válvula de Diafragma"
		],
		image: "/skids-integrados.png",
		icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12H3"></path><path d="m9 6 6 6-6 6"></path><circle cx="12" cy="12" r="3"></circle></svg>`
	},
	{
		title: "Válvulas de Seguridad",
		products: [
			"Válvulas de Seguridad",
			"Válvulas de Alivio",
			"Válvulas de Seguridad de Alivio",
			"Válvulas Operada por Piloto"
		],
		image: "/skids-integrados.png",
		icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>` // Shield/Safety icon
	},
	{
		title: "Actuadores y Posicionadores",
		products: [
			"Actuadores eléctricos",
			"Actuadores neumáticos",
			"Actuadores Electro - Hidráulicos",
			"Actuadores Gas sobre Aceite",
			"Posicionadores"
		],
		image: "/recipientes.png",
		icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4"></path><path d="m16.2 7.8 2.9-2.9"></path><path d="M18 12h4"></path><path d="m16.2 16.2 2.9 2.9"></path><path d="M12 18v4"></path><path d="m7.8 16.2-2.9 2.9"></path><path d="M2 12h4"></path><path d="m7.8 7.8-2.9-2.9"></path><circle cx="12" cy="12" r="6"></circle></svg>` // Mechanical/System icon for Actuators
	},
	{
		title: "Indicadores / Transmisores",
		products: [
			"Presión",
			"Temperatura",
			"Flujo",
			"Nivel"
		],
		image: "/trampas.png",
		icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"></path><path d="m4.93 4.93 4.24 4.24"></path><path d="m14.83 9.17 4.24-4.24"></path><path d="M7 12h10"></path><path d="m9.17 14.83-4.24 4.24"></path><path d="m14.83 14.83 4.24 4.24"></path><circle cx="12" cy="12" r="10"></circle></svg>` // Gauge/Instrument icon
	}
];

const featured = categories[0];
const others = categories.slice(1);
---

<section id="productos" class="products">
	<div class="products-container">
		<div class="products-header fade-in">
			<h2 class="section-title">Productos</h2>
			<p class="products-desc">
				Válvulas, instrumentación y sistemas de actuación de alta precisión para la industria.
			</p>
		</div>

		<div class="products-bento">
			<div class="featured-side fade-in">
				<div class="product-card featured-card">
					<div class="product-image-container featured-img">
						<img src={featured.image} alt={featured.title} class="product-image" loading="lazy" />
						<div class="product-icon-overlay featured-icon" set:html={featured.icon} />
					</div>
					<div class="product-card-content">
						<h3 class="card-title">{featured.title}</h3>
						<ul class="product-list">
							{featured.products.map(product => (
								<li>
									<svg width="6" height="6" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="12"></circle></svg>
									{product}
								</li>
							))}
						</ul>
					</div>
				</div>
			</div>

			<div class="list-side">
				{others.map((cat, index) => (
					<div class={`side-item fade-in delay-${index}`}>
						<div class="side-item-header">
							<div class="side-icon" set:html={cat.icon} />
							<div class="side-info">
								<h3 class="side-title">{cat.title}</h3>
							</div>
							<svg class="side-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
						</div>
						<div class="side-expanded">
							<ul class="product-list compact">
								{cat.products.map(product => (
									<li>
										<svg width="6" height="6" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="12"></circle></svg>
										{product}
									</li>
								))}
							</ul>
						</div>
					</div>
				))}
			</div>
		</div>
	</div>
</section>

<style>
	.products {
		margin-top: -2rem;
		padding: 10rem 2rem;
		background: #ffffff;
		position: relative;
	}

	.products-container {
		max-width: 1400px;
		margin: 0 auto;
	}

	.products-header {
		text-align: left; /* Aligned left for Bento feel */
		max-width: 800px;
		margin-bottom: 5rem;
	}

	.products-desc {
		font-size: 1.15rem;
		color: hsl(var(--text-muted));
		margin-top: 2rem;
		margin-bottom: -2rem;
	}

	/* --- BENTO LAYOUT --- */
	.products-bento {
		display: grid;
		grid-template-columns: 1.1fr 0.9fr;
		gap: 3rem;
		align-items: start;
	}

	@media (max-width: 1024px) {
		.products-bento {
			grid-template-columns: 1fr;
			gap: 4rem;
		}
	}

	/* --- FEATURED CARD --- */
	.product-card {
		background: #ffffff;
		border-radius: 30px;
		transition: var(--transition);
		position: relative;
		overflow: hidden;
		box-shadow: 0 0px 30px -10px gray;
		cursor:pointer;
	}

	.product-card:hover {
		transform: translateY(-5px);
	}

	.featured-card {
		height: 100%;
	}

	.product-image-container {
		height: 250px;
		position: relative;
		overflow: hidden;
		background: hsl(var(--bg-secondary));
	}

	.featured-img {
		height: 350px;
	}

	.product-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s ease;
	}

	.product-card:hover .product-image {
		transform: scale(1.05);
	}

	.product-icon-overlay {
		position: absolute;
		bottom: 2rem;
		left: 2rem;
		width: 50px;
		height: 50px;
		background: #ffffff;
		color: hsl(var(--navy-primary));
		padding: 10px;
		border-radius: 12px;
		box-shadow: 0 15px 35px rgba(0,0,0,0.15);
		z-index: 2;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.product-icon-overlay svg {
		width: 100%;
		height: 100%;
		display: block;
	}

	.card-badge {
		background: hsla(var(--yellow-accent), 0.1);
		color: #856404;
		padding: 0.4rem 0.8rem;
		border-radius: 50px;
		font-size: 0.75rem;
		font-weight: 800;
		text-transform: uppercase;
		display: inline-block;
		margin-bottom: 1rem;
		letter-spacing: 0.05em;
	}

	.product-card-content {
		padding: 3rem;
	}

	.card-title {
		font-size: 2rem;
		margin-bottom: 1rem;
		margin-top: -0.5rem;
		color: hsl(var(--navy-primary));
		letter-spacing: -0.02em;
	}

	/* --- SIDE LIST ITEMS --- */
	.list-side {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.side-item {
		background: #ffffff;
		border: 1px solid hsla(var(--navy-primary), 0.05);
		padding: 1.5rem 2rem;
		border-radius: 4px;
		transition: 0.3s ease;
		cursor: pointer;
		position: relative;
		overflow: hidden;
		box-shadow: 0 10px 30px -15px gray;
	}

	.side-item:hover {
		border-color: hsla(var(--navy-primary), 0.15);
		box-shadow: 0 10px 30px -15px gray;
		transform: translateX(10px);
	}

	.side-item-header {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.side-icon {
		width: 45px;
		height: 45px;
		background: hsla(var(--navy-primary), 0.04);
		color: hsl(var(--navy-primary));
		padding: 10px;
		border-radius: 10px;
		transition: 0.3s ease;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}

	.side-icon svg {
		width: 100%;
		height: 100%;
		display: block;
	}

	.side-info {
		flex: 1;
	}

	.side-title {
		font-size: 1.2rem;
		font-weight: 700;
		color: hsl(var(--navy-primary));
		margin: 0;
	}

	.side-summary {
		font-size: 0.85rem;
		color: hsl(var(--text-muted));
		margin: 4px 0 0 0;
	}

	.side-chevron {
		color: hsla(var(--navy-primary), 0.2);
		transition: transform 0.3s ease;
	}

	.side-item:hover .side-chevron {
		transform: translateX(5px);
		color: hsl(var(--navy-primary));
	}

	/* --- LIST STYLES (SHARED) --- */
	.product-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.product-list li {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
		margin-bottom: 0.85rem;
		font-size: 1rem;
		color: hsl(var(--text-muted));
		line-height: 1.4;
		transition: var(--transition);
		cursor: pointer;
	}

	.product-list li:hover {
		transform: translateX(8px);
		color: hsl(var(--navy-primary));
	}

	.product-list li svg {
		color: hsl(var(--yellow-accent));
		margin-top: 6px;
		flex-shrink: 0;
		transition: var(--transition);
	}

	.product-list li:hover svg {
		transform: scale(1.4);
		filter: drop-shadow(0 0 5px hsla(var(--yellow-accent), 0.5));
	}

	/* Hidden expanded view - ready for JS or hover expansion if needed */
	.side-expanded {
		display: none;
		margin-top: 1.5rem;
		padding-top: 1.5rem;
		border-top: 1px solid hsla(var(--navy-primary), 0.05);
	}

	.side-item:hover .side-expanded {
		display: block;
		animation: slideDown 0.3s ease forwards;
	}

	@keyframes slideDown {
		from { opacity: 0; height: 0; }
		to { opacity: 1; height: auto; }
	}

	@media (max-width: 768px) {
		.products {
			padding: 3rem 5rem;
			margin: 0 auto;
		}
		
		.product-card-content {
			padding: 2rem;
		}

		.featured-img {
			height: 250px;
		}

		.side-item {
			border-radius: 20px;
		}
	}

	@media (max-width: 425px) {
		.products {
			margin-top: -4rem;
			width: 100%;
			padding: 4rem 1rem;
		}
		.products-bento {
			width: 100% !important;
			margin: 0 auto;
		}
		.section-title {
			text-align: center;
		}
		.products-desc {
			text-align: center;
		}
	}

	@media (max-width: 375px) {
		.products {
			margin-top: -4rem;
			width: 100%;
		}
		.products-bento {
			width: 100%;
			margin: 0 auto;
		}
		.section-title {
			text-align: center;
		}
		.products-desc {
			text-align: center;
		}
	}

	@media (max-width: 320px) {
		.products {
			margin-top: -4rem;
			width: 100%;
		}
		.products-bento {
			width: 100%;
			margin: 0 auto;
		}
		.section-title {
			text-align: center;
		}
		.products-desc {
			text-align: center;
		}
	}
	

	/* Micro-animations */
	.delay-0 { animation-delay: 0.1s; }
	.delay-1 { animation-delay: 0.2s; }
	.delay-2 { animation-delay: 0.3s; }
	.delay-3 { animation-delay: 0.4s; }
</style>
