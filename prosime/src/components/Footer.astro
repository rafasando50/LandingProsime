---
const currentYear = new Date().getFullYear();
---
<footer class="footer">
	<div class="footer-container">
		<div class="footer-top grid-container">
			<div class="footer-brand fade-in">
				<div class="footer-logo">
					<img src="/logo/prosimelogo.png" alt="Prosime Industrial Logo" class="footer-brand-logo" />
				</div>
				<p class="brand-desc">
					Líderes en ingeniería de presión y soluciones industriales certificadas ASME. Innovación técnica con seguridad garantizada.
				</p>
				<div class="social-row">
					<a href="#" class="social-icon" aria-label="LinkedIn">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
					</a>
				</div>
			</div>

			<div class="footer-links-group fade-in">
				<h4 class="footer-title">Navegación</h4>
				<ul class="footer-links">
					<li><a href="#inicio">Inicio</a></li>
					<li><a href="#nosotros">Nosotros</a></li>
					<li><a href="#servicios">Servicios</a></li>
					<li><a href="#contacto">Contacto</a></li>
				</ul>
			</div>

			<div class="footer-links-group fade-in">
				<h4 class="footer-title">Capacidades</h4>
				<ul class="footer-links">
					<li><a href="#servicios">Equipos ASME</a></li>
					<li><a href="#servicios">Medición Industrial</a></li>
					<li><a href="#servicios">Sistemas Integrados</a></li>
					<li><a href="#servicios">Válvulas ESD</a></li>
				</ul>
			</div>

			<div class="footer-links-group fade-in">
				<h4 class="footer-title">Ubicación</h4>
				<ul class="footer-links">
					<li>
						<p>Puebla, México. <br />San Francisco Ocotlán.</p>
					</li>
					<li>
						<p>info@prosimeindustrial.com</p>
					</li>
				</ul>
			</div>
		</div>

		<div class="footer-bottom">
			<p>&copy; {currentYear} Prosime Industrial. Excelencia Certificada.</p>
			<div class="footer-legal">
				<a href="#">Privacidad</a>
				<span class="sep">/</span>
				<a href="#">Términos</a>
			</div>
		</div>
	</div>
</footer>

<style>
	.footer {
		background-color: #251d62 !important; /* Brand Navy Background for grounding the page */
		padding: 3rem 2rem 1.5rem; /* Even more compact as requested */
		position: relative;
		color: #ffffff !important;
	}

	.footer-container {
		max-width: 1400px;
		margin: 0 auto;
	}

	.footer-top {
		display: grid;
		grid-template-columns: 1.5fr 1fr 1fr 1fr;
		gap: 3rem; /* Tighter gap */
		margin-bottom: 2.5rem; /* Much smaller margin */
	}

	.footer-logo {
		margin-bottom: 2rem;
	}

	.footer-brand-logo {
		height: 60px; /* Consistent with Navbar but slightly smaller for footer */
		width: auto;
		object-fit: contain;
		filter: brightness(0) invert(1); /* Converting to white for the dark background */
	}

	.brand-desc {
		color: rgba(255, 255, 255, 0.7);
		line-height: 1.7;
		margin-bottom: 2.5rem;
		max-width: 400px;
		font-size: 1.05rem; /* Increased for better presence */
	}

	.social-row {
		display: flex;
		gap: 1.5rem;
	}

	.social-icon {
		width: 42px;
		height: 42px;
		border: 1px solid rgba(255, 255, 255, 0.2);
		border-radius: 4px; /* Squared to match buttons/contact box */
		display: flex;
		align-items: center;
		justify-content: center;
		color: #ffffff;
		transition: var(--transition);
	}

	.social-icon:hover {
		color: hsl(var(--yellow-accent));
		border-color: hsl(var(--yellow-accent));
		background: rgba(250, 204, 21, 0.1);
		transform: translateY(-4px);
	}

	.footer-title {
		font-size: 1rem; /* Much clearer titles */
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.15rem;
		color: hsl(var(--yellow-accent)); /* Yellow accent for headers */
		margin-bottom: 1.5rem;
	}

	.footer-links {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.footer-links li {
		margin-bottom: 1.25rem;
	}

	.footer-links a {
		color: rgba(255, 255, 255, 0.6);
		font-size: 1.05rem;
		font-weight: 700; /* Increased weight as requested */
		transition: var(--transition);
		text-decoration: none; /* No underline for consistency */
	}

	.footer-links a:hover {
		color: #ffffff;
		padding-left: 0; /* Removing the movement to keep it clean */
		text-decoration: none;
	}

	.muted {
		font-size: 0.7rem;
		text-transform: uppercase;
		display: block;
		margin-bottom: 4px;
		color: hsl(var(--text-muted) / 0.6);
		letter-spacing: 0.05rem;
		font-weight: 700;
	}

	.footer-links p {
		color: rgba(255, 255, 255, 0.8);
		font-size: 1.05rem; /* Matched to links for consistency */
		margin: 0;
		font-weight: 700; /* Matched to links weight as requested for "letras" consistency */
	}

	.footer-bottom {
		padding-top: 2rem; /* More compact separation */
		border-top: 1px solid rgba(255, 255, 255, 0.1);
		display: flex;
		justify-content: space-between;
		align-items: center;
		color: rgba(255, 255, 255, 0.4);
		font-size: 0.85rem;
	}

	.footer-legal {
		display: flex;
		gap: 1rem;
		align-items: center;
	}

	.footer-legal a {
		color: inherit;
		transition: var(--transition);
	}

	.footer-legal a:hover {
		color: hsl(var(--navy-primary));
	}

	.sep {
		opacity: 0.3;
	}

	@media (max-width: 992px) {
		.footer-top {
			grid-template-columns: 1fr 1fr;
			gap: 4rem;
		}
	}

	@media (max-width: 640px) {
		.footer-top {
			grid-template-columns: 1fr;
		}
		.footer-bottom {
			flex-direction: column;
			gap: 2rem;
			text-align: center;
		}
	}

	@media (max-width: 425px) {
		.footer-container {
			width: 100% !important;
			padding: 0 1rem;
		}

		.footer-top {
			width: 100%;
			align-items: center;
		}

		.footer {
			width: 100%;
		}

		.footer-title {
			text-align: center;
		}

		.footer-links {
			text-align: center;
			margin-bottom: 0;
		}

		.footer-brand-logo {
			margin: 0 auto 1rem;
			display: block;
		}

		.brand-desc {
			text-align: center;
			margin: 0 auto 2rem;
		}

		.footer-brand {
			width: 100%;
		}

		.social-row {
			justify-content: center;
			margin-left: 0; /* Resetting the left margin hack */
		}

		.social-icon {
			margin-left: 0; /* Resetting the left margin hack */
		}
	}

	@media (max-width: 375px) {
		.footer {
			width: 100%;
		}

		.footer-brand-logo {
			margin: 0 auto 1rem;
		}

		.brand-desc {
			margin: 1rem auto;
		}

		.social-row {
			justify-content: center;
		}
	}

	@media (max-width: 320px) {
		.footer {
			width: 100%;
			background-color: transparent; /* Quitando el verde de prueba */
		}

		.brand-desc {
			font-weight: 500;
		}

		.social-row {
			justify-content: center;
		}
	}	
</style>
