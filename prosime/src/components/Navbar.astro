<nav id="main-nav">
	<div class="nav-container">
		<div class="logo">
			<a href="#inicio">
				<img src="/logo/prosimelogo.png" alt="Prosime Industrial Logo" class="brand-logo" />
			</a>
		</div>
		
		<ul class="nav-links" id="nav-menu">
			<li><a href="#inicio" class="nav-link">Inicio</a></li>
			<li><a href="#nosotros" class="nav-link">Nosotros</a></li>
			<li><a href="#servicios" class="nav-link">Servicios</a></li>
			<li><a href="#contacto" class="btn btn-primary nav-btn">Contacto</a></li>
		</ul>

		<button class="mobile-toggle" id="mobile-toggle" aria-label="Abrir Menú">
			<span></span>
			<span></span>
			<span></span>
		</button>
	</div>
</nav>

<style>
	nav {
		position: fixed; /* Corregido de position: flex */
		top: 0;
		left: 0;
		width: 100%;
		z-index: 1000;
		padding: 0.8rem 0;
		transition: all 0.3s ease;
		background: hsl(var(--navy-primary));
		border-bottom: 2px solid hsla(var(--yellow-accent), 0.3);
	}

	nav.scrolled {
		padding: 0.5rem 0;
		background: hsl(var(--navy-medium));
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
	}

	.nav-container {
		max-width: 1400px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0 1.5rem;
	}

	.brand-logo {
		height: 60px; /* Reducido un poco para que no rompa el diseño inicial */
		width: auto;
		transition: 0.3s ease;
	}

	nav.scrolled .brand-logo {
		height: 45px;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 2.5rem;
		list-style: none;
	}

	.nav-link {
		font-size: 1rem;
		font-weight: 700;
		color: #ffffff;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		text-decoration: none;
	}

	.nav-link:hover {
		color: hsl(var(--yellow-accent));
	}

	.nav-btn {
		background-color: hsl(var(--yellow-accent)) !important;
		color: #312783 !important;
		padding: 0.6rem 1.5rem;
		font-weight: 800;
		border-radius: 4px;
		text-decoration: none;
	}

	/* --- ESTILOS RESPONSIVE --- */
	.mobile-toggle {
		display: none;
		flex-direction: column;
		gap: 6px;
		background: transparent;
		border: none;
		cursor: pointer;
		padding: 10px;
		z-index: 1100;
	}

	.mobile-toggle span {
		width: 30px;
		height: 3px;
		background-color: #fff;
		transition: 0.3s;
	}

	@media (max-width: 992px) {
		.mobile-toggle {
			display: flex;
		}

		/* Menú Lateral que entra desde la derecha */
		.nav-links {
			position: fixed;
			top: 0;
			right: -100%; /* Oculto fuera de pantalla */
			height: 100vh;
			width: 280px;
			background: hsl(var(--navy-primary));
			flex-direction: column;
			justify-content: center;
			padding: 2rem;
			transition: 0.4s ease-in-out;
			box-shadow: -5px 0 15px rgba(0,0,0,0.3);
		}

		.nav-links.active {
			right: 0; /* Entra el menú */
		}

		.brand-logo {
			height: 50px; /* Logo más pequeño en móvil */
		}
	}

	/* Animación del botón X cuando el menú está abierto */
	.mobile-toggle.active span:nth-child(1) {
		transform: translateY(9px) rotate(45deg);
	}
	.mobile-toggle.active span:nth-child(2) {
		opacity: 0;
	}
	.mobile-toggle.active span:nth-child(3) {
		transform: translateY(-9px) rotate(-45deg);
	}
</style>

<script>
	const nav = document.getElementById('main-nav');
	const mobileToggle = document.getElementById('mobile-toggle');
	const navMenu = document.getElementById('nav-menu');

	// Cambio de color al hacer scroll
	window.addEventListener('scroll', () => {
		if (window.scrollY > 20) {
			nav?.classList.add('scrolled');
		} else {
			nav?.classList.remove('scrolled');
		}
	});

	// Abrir/Cerrar menú móvil
	mobileToggle?.addEventListener('click', () => {
		mobileToggle.classList.toggle('active');
		navMenu?.classList.toggle('active');
	});

	// Cerrar el menú al hacer clic en un enlace (importante en landing pages)
	document.querySelectorAll('.nav-link').forEach(link => {
		link.addEventListener('click', () => {
			mobileToggle?.classList.remove('active');
			navMenu?.classList.remove('active');
		});
	});
</script>