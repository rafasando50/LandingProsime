---
const services = [
	{
		title: "Recipientes a Presión",
		icon: "01",
		iconSvg: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3v18"></path><path d="M18 3v18"></path><path d="M3 6h18"></path><path d="M3 18h18"></path><rect x="6" y="6" width="12" height="12"></rect></svg>`,
		features: [
			"Tanques de Condensados",
			"Separadores Bifásicos/Trifásicos",
			"Separadores de Niebla",
			"Reactores y Columnas",
			"Filtros Coalescentes"
		]
	},
	{
		title: "Tanques API y Trampas",
		icon: "02",
		iconSvg: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"></path><path d="M5 2h14"></path><path d="M5 22h14"></path><path d="M3 7h18"></path><path d="M3 17h18"></path></svg>`,
		features: [
			"Tanques de Almacenamiento Atmosférico",
			"Tanques de Químicos",
			"Trampas de envio y recibo de Diablos"
		]
	},
	{
		title: "Skids para Producción",
		icon: "03",
		iconSvg: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="12" y1="3" x2="12" y2="21"></line><line x1="3" y1="12" x2="21" y2="12"></line></svg>`,
		features: [
			"Skids Dosificadores",
			"Mezcladores Estáticos",
			"Hidrociclones"
		]
	},
	{
		title: "Skids Integrados",
		icon: "04",
		iconSvg: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><circle cx="12" cy="10" r="3"></circle></svg>`,
		features: [
			"Patines de Medición para crudo",
			"Patines de Medición para Gas",
			"Patines de Regulación de Presión",
			"Patines de Separación para Gas"
		]
	}
];
---
<section id="servicios" class="services">
	<div class="services-container">
		<div class="services-header fade-in">
			<h2 class="section-title">Soluciones Integrales</h2>
		</div>
		
		<div class="services-grid grid">
			{services.map(service => (
				<div class="service-card light-card">
					<div class="service-icon-header">
						<div class="icon-circle" set:html={service.iconSvg} />
					</div>
					<div class="service-content">
						<span class="service-number">{service.icon}</span>
						<h3 class="service-title">{service.title}</h3>
						
						<ul class="service-features">
							{service.features.map(feature => (
								<li>
									<svg width="6" height="6" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="12"></circle></svg>
									{feature}
								</li>
							))}
						</ul>

						<a href="#contacto" class="service-btn">
							Más Información
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
						</a>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.section-title {
		margin-bottom: -1.5rem;
		text-align: center;
	}
	.services {
		background: hsl(var(--bg-secondary));
		padding: 10rem 2rem;
		margin-top: -5rem;
	}

	.services-container {
		max-width: 1400px;
		margin: 0 auto;
	}

	.services-header {
		margin-bottom: 5rem;
		text-align: left;
	}

	.section-label {
		font-size: 0.75rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.2rem;
		color: hsl(var(--text-muted));
		margin-bottom: 1rem;
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 2rem;
	}

	.service-card {
		display: flex;
		flex-direction: column;
		height: 100%;
		width: 100%;
		overflow: hidden;
		border-radius: 12px;
		background: #ffffff;
		box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08); 
		cursor: pointer;
	}

	.service-card:hover {
		box-shadow: 0 10px 40px rgba(0, 0, 0, 0.25); 
		transform: translateY(-5px);
	}

	.service-icon-header {
		height: 160px;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2.5rem 2.5rem 0 2.5rem;
		position: relative;
		margin-bottom: -1rem;
		margin-top: -1rem;
	}

	.icon-circle {
		width: 80px;
		height: 80px;
		background: linear-gradient(135deg, #ffffff, hsla(var(--navy-primary), 0.03));
		color: hsl(var(--navy-primary));
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 1px solid hsla(var(--navy-primary), 0.1);
		transition: var(--transition);
		box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
	}

	/*
	.service-card:hover .icon-circle {
		background: hsl(var(--navy-primary));
		color: #ffffff;
		transform: scale(1.05) translateY(-5px);
		box-shadow: 0 10px 15px hsla(var(--navy-primary), 0.15);
		border-color: transparent;
	} */


	.service-content {
		position: relative;
		padding: 2rem 1.75rem;
		flex: 1;
		display: flex;
		flex-direction: column;
		z-index: 2;
	}

	.service-number {
		position: absolute;
		top: 2.5rem;
		right: 2.5rem;
		font-family: 'Outfit', sans-serif;
		font-size: 3rem;
		font-weight: 800;
		color: hsl(var(--navy-primary) / 0.05);
		line-height: 1;
	}

	.service-title {
		font-size: 1.5rem;
		margin-top: 0.5rem;
		margin-bottom: 2rem;
		color: hsl(var(--navy-primary));
		letter-spacing: -0.02em;
	}

	.service-features {
		list-style: none;
		padding: 0;
		margin: -0.8rem 0 2.5rem 0;
		flex: 1;
	}

	.service-features li {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 1.1rem;
		color: hsl(var(--text-muted));
		margin-bottom: 10px;
		line-height: 1.7;
		transition: var(--transition);
		cursor: pointer;
	}

	.service-features li:hover {
		transform: translateX(8px);
		color: hsl(var(--navy-primary));
	}

	.service-features li svg {
		color: hsl(var(--yellow-accent));
		flex-shrink: 0;
		transition: var(--transition);
	}

	.service-features li:hover svg {
		transform: scale(1.4);
		filter: drop-shadow(0 0 5px hsla(var(--yellow-accent), 0.5));
	}

	.service-btn {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		font-size: 0.875rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: hsl(var(--navy-primary));
		transition: var(--transition);
		width: fit-content;
		text-decoration: none; /* Removing underline */
	}

	.service-btn:hover {
		color: hsl(var(--yellow-accent));
		transform: translateX(5px);
		text-decoration: none; /* Ensuring no underline on hover */
	}

	@media (max-width: 425px) {
		.services-container {
			width: 100% !important;
			padding: 0 1rem;
		}
		.services {
			width: 100%;
			margin-left: 0;
		}
		.section-title {
			text-align: center;
			width: 100%;
			margin-left: 0;
		}
		.service-title {
			text-align: center;
		}
		.service-features {
			margin: -10px auto 25px auto;
		}
		.service-btn {
			margin: 0 auto;
		}
	}	

	@media (max-width: 375px)  {
		.services {
			width: 100%;
			margin-left: 0;
		}
		.section-title {
			text-align: center;
			margin-bottom: -5%;
		}
		.service-title {
			text-align: center;
		}	
		.service-features {
			margin: -5px auto 25px auto;
		}
		.service-btn {
			margin: 0 auto;
		}
	}

	@media (max-width: 320px) {
		.services {
			width: 100%;
			margin-left: 0;
			height: 100%;
			margin-bottom: -20%;
		}

		.section-title  {
			width: 100%;
			text-align: center;
			margin: -1rem auto -1rem auto;
		}
		.service-title {
			text-align: center;
		}
		.service-features  {
			margin: -5px auto 20px auto;

		}
		.service-btn {
			margin: 0 auto;
		}
	}
</style>
