---
const services = [
	{
		title: "Recipientes a Presión",
		icon: "01",
		image: "/recipientes.png",
		features: [
			"Tanques de Condensados",
			"Separadores Bifásicos/Trifásicos",
			"Separadores de Niebla",
			"Reactores y Columnas",
			"Filtros Coalescentes"
		]
	},
	{
		title: "Tanques API y Trampas",
		icon: "02",
		image: "/trampas.png",
		features: [
			"Tanques de Almacenamiento Atmosférico",
			"Tanques de Químicos",
			"Trampas de envio y recibo de Diablos"
		]
	},
	{
		title: "Skids para Producción",
		icon: "03",
		image: "/skids-produccion.png",
		features: [
			"Skids Dosificadores",
			"Mezcladores Estáticos",
			"Hidrociclones"
		]
	},
	{
		title: "Skids Integrados",
		icon: "04",
		image: "/skids-integrados.png",
		features: [
			"Patines de Medición para crudo",
			"Patines de Medición para Gas",
			"Patines de Regulación Alta Caída de Presión",
			"Patines de Separación para Gas"
		]
	}
];
---
<section id="servicios" class="services">
	<div class="services-container">
		<div class="services-header fade-in">
			<h2 class="section-title">Soluciones Integrales</h2>
		</div>
		
		<div class="services-grid grid">
			{services.map(service => (
				<div class="service-card light-card">
					<div class="service-image">
						<img src={service.image} alt={service.title} loading="lazy" />
					</div>
					<div class="service-content">
						<span class="service-number">{service.icon}</span>
						<h3 class="service-title">{service.title}</h3>
						
						<ul class="service-features">
							{service.features.map(feature => (
								<li>
									<svg width="6" height="6" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="12"></circle></svg>
									{feature}
								</li>
							))}
						</ul>

						<a href="#contacto" class="service-btn">
							Más Información
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
						</a>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.section-title {
		margin-bottom: -1.5rem;
		text-align: center;
	}
	.services {
		background: hsl(var(--bg-secondary));
		padding: 10rem 2rem;
	}

	.services-container {
		max-width: 1800px;
		margin: 0 auto;
	}

	.services-header {
		margin-bottom: 5rem;
		text-align: left;
	}

	.section-label {
		font-size: 0.75rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.2rem;
		color: hsl(var(--text-muted));
		margin-bottom: 1rem;
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: 2rem;
	}

	.service-card {
		display: flex;
		flex-direction: column;
		height: 100%;
		width: 100%;
		overflow: hidden;
		border-radius: 12px;
		background: #ffffff;
		box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08); /* Sophisticated shadow for subtle separation */
	}

	.service-image {
		height: 240px;
		overflow: hidden;
		position: relative;
	}

	.service-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s ease;
		opacity: 1;
		filter: none;
	}

	.service-card:hover .service-image img {
		transform: scale(1.1);
	}


	.service-content {
		position: relative;
		padding: 2.5rem;
		flex: 1;
		display: flex;
		flex-direction: column;
		z-index: 2;
	}

	.service-number {
		position: absolute;
		top: 2.5rem;
		right: 2.5rem;
		font-family: 'Outfit', sans-serif;
		font-size: 3rem;
		font-weight: 800;
		color: hsl(var(--navy-primary) / 0.05);
		line-height: 1;
	}

	.service-title {
		font-size: 1.5rem;
		margin-top: 0.5rem;
		margin-bottom: 2rem;
		color: hsl(var(--navy-primary));
		letter-spacing: -0.02em;
	}

	.service-features {
		list-style: none;
		padding: 0;
		margin: -0.8rem 0 2.5rem 0;
		flex: 1;
	}

	.service-features li {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 1.1rem;
		color: hsl(var(--text-muted));
		margin-bottom: 10px;
		line-height: 1.7;
		transition: var(--transition);
		cursor: pointer;
	}

	.service-features li:hover {
		transform: translateX(8px);
		color: hsl(var(--navy-primary));
	}

	.service-features li svg {
		color: hsl(var(--yellow-accent));
		flex-shrink: 0;
		transition: var(--transition);
	}

	.service-features li:hover svg {
		transform: scale(1.4);
		filter: drop-shadow(0 0 5px hsla(var(--yellow-accent), 0.5));
	}

	.service-btn {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		font-size: 0.875rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: hsl(var(--navy-primary));
		transition: var(--transition);
		width: fit-content;
		text-decoration: none; /* Removing underline */
	}

	.service-btn:hover {
		color: hsl(var(--yellow-accent));
		transform: translateX(5px);
		text-decoration: none; /* Ensuring no underline on hover */
	}

	@media (max-width: 425px) {
		.services {
			width: 350px;
			margin-left:10%;
		}
		.section-title {
			text-align: center;
			width: 120%;
			margin-left: -10%;
			
	}	

	@media (max-width: 375px)  {
		.services {
			width: 450px;
			margin-left: 10%;
		}

		.section-title {
			text-align: center;
			margin-bottom: -5%;
		}
	}

	@media (max-width: 320px) {
		.services {
			width: 138%;
		}

		.section-title  {
			width:101%;
			text-align: center;
			margin-bottom: -5%;
		}
	}
</style>
