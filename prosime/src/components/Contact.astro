---
---
<section id="contacto" class="contact">
	<div class="contact-container">
		<div class="contact-card light-card fade-in">
			<div class="contact-grid">
				<div class="contact-content">
					<div class="section-label">Contacto Técnico</div>
					<h2 class="section-title">Inicie su <br /><span class="gradient-text">Proyecto Certificado</span></h2>
					<p class="contact-desc">
						Transformamos sus requerimientos de ingeniería en soluciones tangibles de alto rendimiento bajo estándares ASME.
					</p>
					
					<div class="contact-methods">
						<div class="method-item">
							<div class="method-icon">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
							</div>
							<div class="method-text">
								<strong>Email Oficial</strong>
								<a href="mailto:info@prosimeindustrial.com">info@prosimeindustrial.com</a>
							</div>
						</div>
						
						<div class="method-item">
							<div class="method-icon">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
							</div>
							<div class="method-text">
								<strong>Oficina Puebla</strong>
								<span>San Francisco Ocotlán, México.</span>
							</div>
						</div>
					</div>
				</div>

				<div class="contact-form-side">
					<form id="contact-form" class="contact-form">
						<input type="hidden" name="access_key" value="8d0c3111-266f-429d-8a67-57d36f4e38c4" />
						<input type="hidden" name="from_name" value="Prosime Industrial Landing" />
						<input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

						<div class="form-row grid">
							<div class="input-group">
								<input type="text" name="name" id="name" placeholder=" " required />
								<label for="name">Nombre Completo</label>
							</div>
							<div class="input-group">
								<input type="email" name="email" id="email" placeholder=" " required />
								<label for="email">Empresa / Email</label>
							</div>
						</div>
						<div class="input-group">
							<input type="text" name="subject" id="subject" placeholder=" " required />
							<label for="subject">Asunto del Proyecto</label>
						</div>
						<div class="input-group">
							<textarea name="message" id="message" placeholder=" " rows="4" required></textarea>
							<label for="message">Detalles Técnicos</label>
						</div>
						
						<div id="form-status" class="form-status"></div>

						<button type="submit" id="submit-btn" class="btn btn-primary form-submit">
							<span class="btn-text">Enviar Consulta</span>
							<span class="btn-loader hidden">
								<svg class="animate-spin" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg>
							</span>
							<svg class="submit-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
						</button>
					</form>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.contact {
		background: hsl(var(--bg-primary));
		padding: 10rem 2rem;
		position: relative;
	}

	.contact-container {
		max-width: 1400px;
		margin: 0 auto;
	}

	.contact-card {
		padding: 2rem; /* Reduced to allow side boxes to shine */
		border-radius: 0;
		background: transparent; /* Making the outer card transparent to show the inner boxes */
		box-shadow: none; /* Removing outer shadow as inner boxes now have them */
	}

	.contact-grid {
		display: grid;
		grid-template-columns: 0.8fr 1.2fr;
		gap: 0; /* Removing the gap to join the boxes */
		align-items: stretch; /* Ensuring equal height */
		box-shadow: 0 30px 100px -10px rgba(10, 25, 47, 0.2); /* Single shadow for the joined block */
	}

	.section-label {
		font-size: 0.75rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.2rem;
		color: hsl(var(--text-muted));
		margin-bottom: 1rem;
	}

	.contact-content {
		padding: 4rem;
		background: #ffffff;
		border: none;
		border-radius: 0;
		border-right: 1px solid hsla(var(--navy-primary), 0.05); /* Subtle internal divider */
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.contact-desc {
		color: hsl(var(--text-muted));
		font-size: 1.1rem;
		margin-bottom: 3rem;
		max-width: 100%;
	}

	.contact-methods {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.method-item {
		display: flex;
		gap: 1.5rem;
		align-items: center;
	}

	.method-icon {
		width: 48px;
		height: 48px;
		border-radius: 12px;
		background: hsla(var(--navy-primary), 0.05);
		color: hsl(var(--navy-primary));
		display: flex;
		align-items: center;
		justify-content: center;
		border: 1px solid hsla(var(--navy-primary), 0.1);
	}

	.method-text strong {
		display: block;
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.1rem;
		color: hsl(var(--text-muted));
		margin-bottom: 4px;
	}

	.method-text a, .method-text span {
		color: hsl(var(--navy-primary));
		font-weight: 700;
	}

	.contact-form-side {
		padding: 4rem;
		background: #ffffff;
		border: none;
		border-radius: 0;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.contact-form {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}

	.form-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2rem;
	}

	.input-group {
		position: relative;
	}

	input, textarea {
		width: 100%;
		padding: 1.2rem 1.5rem;
		background: #ffffff !important;
		border: 1px solid hsla(var(--navy-primary), 0.1);
		color: hsl(var(--navy-primary));
		font-family: inherit;
		font-size: 1rem;
		transition: var(--transition);
		border-radius: 4px;
		box-shadow: 0 10px 35px rgba(0, 0, 0, 0.18); /* Much deeper shadow as requested */
	}

	input:focus, textarea:focus {
		outline: none;
		border-color: #312783;
		background: #ffffff !important;
		box-shadow: 0 15px 45px -5px rgba(10, 25, 47, 0.35); /* Intense focus glow and lift */
	}

	label {
		position: absolute;
		top: 1rem;
		left: 1.5rem; /* Aligned with input padding */
		color: hsl(var(--text-muted));
		font-size: 0.875rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		pointer-events: none;
		transition: var(--transition);
		font-weight: 600;
	}

	input:focus ~ label,
	input:not(:placeholder-shown) ~ label,
	textarea:focus ~ label,
	textarea:not(:placeholder-shown) ~ label {
		top: -1.7rem;
		left: 0;
		font-size: 0.75rem;
		color: #312783;
		font-weight: 800;
	}

	.form-submit {
		margin-top: 1rem;
		gap: 12px;
		width: fit-content;
	}

	@media (max-width: 992px) {
		.contact-grid {
			grid-template-columns: 1fr;
			gap: 4rem;
		}
		.contact-card {
			padding: 2.5rem;
		}
		.form-row {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 1024px) {
		.contact-form-side {
			padding-right: 18%;
		}
		.btn-primary {

		}
	}

	@media (max-width: 768px) {
		.contact-form-side {
			padding-right: 17%;
		}
		.btn-primary {
			margin-left: 25%;		
		}
	}

	@media (max-width: 425px) {
		.contact-container {
			width: 100% !important;
			padding: 0 1rem;
		}
		.contact {
			width: 100%;
			margin-left: 0;
		}

		.contact-form-side {
			margin-top: 2rem;
			margin-left: 0;
			width: 100%;
			padding-right: 0;
		}

		.contact-content {
			margin-left: 0;
			width: 100%;
		}

		.btn-primary {
			margin-left: 0;
		}
	}

	@media (max-width: 375px) {
		.contact {
			width: 100%;
			margin-left: 0;
		}

		.contact-form-side {
			margin-top: 2rem;
			margin-left: 0;
			width: 100%;
			padding-right: 0;
		}

		.contact-content{
			margin-left: 0;
			width: 100%;
		}

		.btn-primary {
			margin-left: 0;
		}
	}

	@media (max-width: 320px) {
		.contact {
			width: 100%;
			margin-left: 0;
		}

		.contact-form-side {
			margin-top: 2rem;
			margin-left: 0;
			width: 100%;
			padding-right: 0;
		}

		.contact-content{
			margin-left: 0;
			width: 100%;
		}

		.btn-primary {
			margin-left: 0;
		}
	}

	/* Status Message Styles */
	.form-status {
		font-size: 0.9rem;
		font-weight: 600;
		padding: 1rem;
		border-radius: 4px;
		display: none;
		animation: slideDown 0.3s ease forwards;
	}

	.form-status.success {
		display: block;
		background: #ecfdf5;
		color: #065f46;
		border: 1px solid #10b981;
	}

	.form-status.error {
		display: block;
		background: #fef2f2;
		color: #991b1b;
		border: 1px solid #ef4444;
	}

	.hidden {
		display: none;
	}

	@keyframes slideDown {
		from { opacity: 0; transform: translateY(-10px); }
		to { opacity: 1; transform: translateY(0); }
	}

	.animate-spin {
		animation: spin 1s linear infinite;
	}

	@keyframes spin {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}
</style>

<script>
	const contactForm = document.getElementById('contact-form') as HTMLFormElement;
	const statusMsg = document.getElementById('form-status');
	const submitBtn = document.getElementById('submit-btn');
	const btnText = submitBtn?.querySelector('.btn-text');
	const btnLoader = submitBtn?.querySelector('.btn-loader');
	const submitIcon = submitBtn?.querySelector('.submit-icon');

	contactForm?.addEventListener('submit', async (e) => {
		e.preventDefault();
		
		// Reset status
		if (statusMsg) {
			statusMsg.textContent = '';
			statusMsg.className = 'form-status';
		}

		// Loading state
		if (submitBtn) submitBtn.setAttribute('disabled', 'true');
		if (btnText) btnText.textContent = 'Enviando...';
		btnLoader?.classList.remove('hidden');
		submitIcon?.classList.add('hidden');

		const formData = new FormData(contactForm);
		const object = Object.fromEntries(formData);
		const json = JSON.stringify(object);

		try {
			const response = await fetch('https://api.web3forms.com/submit', {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
					'Accept': 'application/json'
				},
				body: json
			});

			const result = await response.json();

			if (response.status === 200) {
				if (statusMsg) {
					statusMsg.textContent = '¡Mensaje enviado con éxito! Nos pondremos en contacto pronto.';
					statusMsg.classList.add('success');
				}
				contactForm.reset();
			} else {
				throw new Error(result.message || 'Error al enviar');
			}
		} catch (error) {
			if (statusMsg) {
				statusMsg.textContent = 'Hubo un error al enviar el mensaje. Por favor, intenta de nuevo.';
				statusMsg.classList.add('error');
			}
		} finally {
			// Restore button state
			if (submitBtn) submitBtn.removeAttribute('disabled');
			if (btnText) btnText.textContent = 'Enviar Consulta';
			btnLoader?.classList.add('hidden');
			submitIcon?.classList.remove('hidden');
		}
	});
</script>
